<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>teaql.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence TeaQL execution logs on console, write to file -->
    <logger name="ExecutionLog" level="DEBUG" additivity="false">
        <appender-ref ref="FILE" />
    </logger>
    
    <logger name="io.teaql" level="DEBUG" additivity="false">
        <appender-ref ref="FILE" />
    </logger>

    <root level="ERROR">
        <appender-ref ref="FILE" />
    </root>
</configuration>
